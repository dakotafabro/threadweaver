{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threadweaver.dev/schemas/chatgpt-export/manifest.schema.json",
  "title": "Threadweaver ChatGPT Export Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "export_id", "source", "exported_at", "exporter", "selection", "counts", "files"],
  "properties": {
    "spec_version": { "type": "string", "pattern": "^0\\.1\\.[0-9]+$" },
    "export_id": { "type": "string", "minLength": 1 },
    "source": { "const": "chatgpt" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exporter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "project_ids", "chat_ids", "time_range"],
      "properties": {
        "mode": { "enum": ["projects", "chats", "mixed", "time_range"] },
        "project_ids": { "type": "array", "items": { "type": "string" } },
        "chat_ids": { "type": "array", "items": { "type": "string" } },
        "time_range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["after", "before"],
          "properties": {
            "after": { "type": ["string", "null"], "format": "date-time" },
            "before": { "type": ["string", "null"], "format": "date-time" }
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projects", "conversations", "messages"],
      "properties": {
        "projects": { "type": "integer", "minimum": 0 },
        "conversations": { "type": "integer", "minimum": 0 },
        "messages": { "type": "integer", "minimum": 0 }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_pii_possible", "redactions_applied"],
      "properties": {
        "contains_pii_possible": { "type": "boolean" },
        "redactions_applied": { "type": "boolean" }
      }
    }
  }
}