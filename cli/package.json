{
  "name": "@dakotafabrodev/threadweaver-cli",
  "version": "0.1.2",
  "description": "ThreadWeaver CLI for ChatGPT export ingestion, policy-scoped recall, and local-first memory workflows",
  "keywords": [
    "threadweaver",
    "chatgpt-export",
    "goose",
    "memory",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "threadweaver": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@dakotafabrodev/threadweaver-dashboard": "^0.1.2",
    "@dakotafabrodev/threadweaver-mcp": "^0.1.2",
    "@dakotafabrodev/threadweaver-sdk": "^0.1.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
